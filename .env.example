# Supabase — usado pelos scripts/skills locais (voice-profile-backfill, nutrir-contatos)
SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Google OAuth (opcional — sync de contatos via sync-google-contacts)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Setup/deploy completo (todas as variáveis, por provider): .claude/skills/setup/SKILL.md, seção 1.
# Os cron jobs internos leem URL + service_role do Supabase Vault (populado no setup,
# seção 2.1 da skill) — nada de app.settings/ALTER DATABASE.
